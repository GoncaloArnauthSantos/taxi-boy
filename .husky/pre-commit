#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."
echo ""

echo "📝 Type checking..."
npm run type-check || {
  echo ""
  echo "❌ Type check failed. Please fix the errors before committing."
  exit 1
}

echo ""
echo "🔍 Linting..."
npm run lint || {
  echo ""
  echo "❌ Lint failed. Please fix the errors before committing."
  exit 1
}

echo ""
echo "✅ Pre-commit checks passed! Committing..."
